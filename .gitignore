# Common — language-agnostic baseline. Python dev-artefact ignores are
# in the "Python" section below; FIBR-0002 expands that into the full set
# (local vaults, *.db, packaging output: *.dmg / AppImage / dist).

# Python — bytecode caches and the local dev virtualenv (.venv is also
# allowlisted in .gitleaks.toml and excluded by bandit).
__pycache__/
*.py[cod]
.venv/

# OS
.DS_Store
Thumbs.db
desktop.ini
*.bak
*.orig
*.rej

# Editor / IDE
.idea/
.vscode/
*.code-workspace
*.swp
*.swo
*~
.#*
\#*\#

# Secrets / local env
.env
.env.*
!.env.example

# Claude Code (local settings, history, allowlist — mostly personal).
# Drop the trailing slash so the negations below can re-include
# specific files; with `.claude/` git short-circuits at the
# directory and ignores the !.claude/foo lines.
.claude/*
# Team-shared Claude Code config that SHOULD be in version control:
!.claude/settings.json
!.claude/workflow.md

# Logs / runtime
*.log
*.pid
*.sock

# Coverage / sanitizers
*.gcda
*.gcno
*.gcov
coverage.*
.coverage
lcov.info

# Core dumps
core
core.*
*.core
vgcore.*

# Scratch
scratch/
tmp/
Screenshot_*.png
screenshot*.png
